/* app.wxss - Global Styles */
page {
  background-color: #F5F7FA;
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", sans-serif;
  color: #333;
  font-size: 28rpx;
  box-sizing: border-box;
}

.container {
  min-height: 100vh;
  padding: 30rpx;
  box-sizing: border-box;
}

/* Card styles */
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

/* Button styles */
.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #4A90D9, #357ABD);
  color: #fff;
  border-radius: 50rpx;
  height: 96rpx;
  font-size: 34rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.4);
}

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.btn-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  color: #4A90D9;
  border: 2rpx solid #4A90D9;
  border-radius: 50rpx;
  height: 96rpx;
  font-size: 34rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  box-shadow: none;
}

.btn-secondary:active {
  background: #EBF3FB;
}

/* Text helpers */
.text-center {
  text-align: center;
}

.text-muted {
  color: #999;
  font-size: 26rpx;
}

/* Section title */
.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 20rpx;
}
