@import "styles/theme.wxss";

page {
  background-color: var(--bg-primary);
  color: var(--text-primary);
  font-family: -apple-system, "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
}

* {
  box-sizing: border-box;
}

.container {
  min-height: 100vh;
  background-color: var(--bg-primary);
  padding: 0 0 env(safe-area-inset-bottom);
}

/* Buttons */
.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  background: var(--accent);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  letter-spacing: 2rpx;
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  background: transparent;
  color: var(--text-secondary);
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: 2rpx solid var(--border-light);
}

.btn-secondary::after {
  border: none;
}

.btn-danger {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  background: transparent;
  color: var(--accent-danger);
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: 2rpx solid var(--accent-danger);
}

.btn-danger::after {
  border: none;
}

/* Cards */
.card {
  background: var(--bg-card);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid var(--border);
}

/* Score color classes */
.score-low { color: var(--accent); }
.score-medium { color: var(--accent-warn); }
.score-high { color: var(--accent-danger); }

.badge-low {
  background: rgba(76, 195, 138, 0.15);
  color: var(--accent);
  border-radius: 8rpx;
  padding: 4rpx 16rpx;
  font-size: 24rpx;
}

.badge-medium {
  background: rgba(245, 166, 35, 0.15);
  color: var(--accent-warn);
  border-radius: 8rpx;
  padding: 4rpx 16rpx;
  font-size: 24rpx;
}

.badge-high {
  background: rgba(229, 83, 75, 0.15);
  color: var(--accent-danger);
  border-radius: 8rpx;
  padding: 4rpx 16rpx;
  font-size: 24rpx;
}

/* Text utilities */
.text-primary { color: var(--text-primary); }
.text-secondary { color: var(--text-secondary); }
.text-muted { color: var(--text-muted); }
.text-accent { color: var(--accent); }
.text-warn { color: var(--accent-warn); }
.text-danger { color: var(--accent-danger); }

.text-center { text-align: center; }
.text-bold { font-weight: 600; }

/* Divider */
.divider {
  height: 1rpx;
  background: var(--border);
  margin: 24rpx 0;
}

/* Loading state */
.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 400rpx;
}
