.container {
  min-height: 100vh;
  background: var(--bg-primary);
  display: flex;
  flex-direction: column;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

/* Progress */
.progress-section {
  padding: 24rpx 32rpx 16rpx;
  background: var(--bg-primary);
  position: sticky;
  top: 0;
  z-index: 10;
  border-bottom: 1rpx solid var(--border);
}

.progress-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.progress-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.progress-pct {
  font-size: 24rpx;
  color: var(--accent);
  font-weight: 600;
}

.progress-track {
  height: 8rpx;
  background: var(--border);
  border-radius: 100rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.progress-fill {
  height: 100%;
  background: var(--accent);
  border-radius: 100rpx;
  transition: width 0.4s ease;
}

.step-labels {
  display: flex;
  justify-content: space-between;
}

.step-lbl {
  font-size: 20rpx;
  color: var(--text-muted);
  flex: 1;
  text-align: center;
}

.step-lbl--active {
  color: var(--accent);
  font-weight: 600;
}

/* Step scroll */
.step-scroll {
  flex: 1;
}

.step-content {
  padding: 32rpx 32rpx 40rpx;
}

.step-title-wrap {
  margin-bottom: 32rpx;
}

.step-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.step-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-muted);
}

/* Cards */
.card {
  background: var(--bg-card);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid var(--border);
}

/* Field labels */
.field-label {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
  margin-bottom: 20rpx;
  line-height: 1.5;
}

.field-label--required::after {
  content: ' *';
  color: var(--accent-danger);
}

/* Option chips */
.option-group {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.option-chip {
  padding: 14rpx 24rpx;
  border-radius: 100rpx;
  border: 1rpx solid var(--border-light);
  background: var(--bg-elevated);
  color: var(--text-secondary);
  font-size: 24rpx;
  transition: all 0.2s;
}

.option-chip.selected {
  border-color: var(--accent);
  background: rgba(76, 195, 138, 0.12);
  color: var(--accent);
}

.ls-options {
  flex-direction: column;
}

.ls-chip {
  border-radius: 12rpx;
  padding: 18rpx 24rpx;
  font-size: 26rpx;
}

/* Number input */
.num-input-wrap {
  display: flex;
  align-items: center;
  background: var(--bg-elevated);
  border: 1rpx solid var(--border-light);
  border-radius: 12rpx;
  overflow: hidden;
}

.num-input {
  flex: 1;
  height: 88rpx;
  padding: 0 24rpx;
  color: var(--text-primary);
  font-size: 28rpx;
  background: transparent;
}

.num-unit {
  padding: 0 24rpx;
  color: var(--text-muted);
  font-size: 24rpx;
  border-left: 1rpx solid var(--border);
}

/* Frequency legend */
.freq-legend {
  display: flex;
  justify-content: space-around;
  padding: 16rpx 0;
  margin-bottom: 16rpx;
  background: var(--bg-card);
  border-radius: 12rpx;
  border: 1rpx solid var(--border);
}

.freq-legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.freq-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.freq-dot-0 { background: var(--accent); }
.freq-dot-1 { background: #63a8d3; }
.freq-dot-2 { background: var(--accent-warn); }
.freq-dot-3 { background: var(--accent-danger); }

.freq-legend-text {
  font-size: 20rpx;
  color: var(--text-muted);
}

/* Group header */
.group-header {
  display: flex;
  align-items: center;
  padding: 16rpx 0 12rpx;
  margin-bottom: 8rpx;
  border-bottom: 1rpx solid var(--border);
  margin-top: 16rpx;
}

.group-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.group-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  flex: 1;
}

.group-count {
  font-size: 22rpx;
  color: var(--text-muted);
  background: var(--bg-elevated);
  padding: 4rpx 16rpx;
  border-radius: 100rpx;
}

/* Question card */
.question-card {
  padding: 24rpx;
}

.q-text-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 16rpx;
  gap: 16rpx;
}

.q-text {
  font-size: 26rpx;
  color: var(--text-primary);
  line-height: 1.6;
  flex: 1;
}

.red-flag-badge {
  background: rgba(229, 83, 75, 0.15);
  border: 1rpx solid rgba(229, 83, 75, 0.3);
  border-radius: 8rpx;
  padding: 4rpx 12rpx;
  flex-shrink: 0;
}

.red-flag-badge text {
  font-size: 20rpx;
  color: var(--accent-danger);
}

/* Frequency scale */
.freq-scale {
  display: flex;
  gap: 10rpx;
}

.freq-btn {
  flex: 1;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 10rpx;
  border: 1rpx solid var(--border-light);
  background: var(--bg-elevated);
  color: var(--text-muted);
  font-size: 20rpx;
  text-align: center;
  line-height: 1.3;
  padding: 0 4rpx;
}

.freq-btn.active-0 {
  border-color: var(--accent);
  background: rgba(76, 195, 138, 0.1);
  color: var(--accent);
  font-weight: 600;
}

.freq-btn.active-1 {
  border-color: #63a8d3;
  background: rgba(99, 168, 211, 0.1);
  color: #63a8d3;
  font-weight: 600;
}

.freq-btn.active-2 {
  border-color: var(--accent-warn);
  background: rgba(245, 166, 35, 0.1);
  color: var(--accent-warn);
  font-weight: 600;
}

.freq-btn.active-3 {
  border-color: var(--accent-danger);
  background: rgba(229, 83, 75, 0.1);
  color: var(--accent-danger);
  font-weight: 600;
}

.skip-tip {
  margin: 16rpx 0 40rpx;
}

.skip-tip-text {
  font-size: 24rpx;
  color: var(--text-muted);
}

/* Bottom buttons */
.bottom-btns {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  background: var(--bg-primary);
  border-top: 1rpx solid var(--border);
}

.btn-prev {
  flex: 1;
  height: 88rpx;
  background: transparent;
  border: 1rpx solid var(--border-light);
  border-radius: 44rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
}

.btn-prev::after { border: none; }

.btn-next {
  flex: 2;
  height: 88rpx;
  background: var(--accent);
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  border: none;
}

.btn-next::after { border: none; }

.btn-next--finish {
  background: linear-gradient(135deg, var(--accent), #3aaa75);
  box-shadow: 0 6rpx 24rpx rgba(76, 195, 138, 0.4);
}

.btn-next[disabled] {
  opacity: 0.6;
}
