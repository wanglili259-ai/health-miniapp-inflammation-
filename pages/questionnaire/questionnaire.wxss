/* pages/questionnaire/questionnaire.wxss */

.container {
  padding: 24rpx 24rpx 80rpx;
}

/* Progress */
.progress-wrap {
  padding: 28rpx 32rpx;
  margin-bottom: 28rpx;
}

.progress-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.progress-label {
  font-size: 26rpx;
  color: #666;
}

.progress-count {
  font-size: 28rpx;
  font-weight: 700;
  color: #4A90D9;
}

.progress-bar-bg {
  width: 100%;
  height: 12rpx;
  background: #E8EDF3;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #4A90D9, #27AE60);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

/* Group header */
.group-header {
  font-size: 26rpx;
  font-weight: 700;
  color: #4A90D9;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  padding: 24rpx 8rpx 12rpx;
}

/* Question card */
.question-card {
  padding: 30rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid transparent;
  transition: border-color 0.2s;
}

.question-card.answered {
  border-color: #D5E8F7;
}

.question-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.q-num {
  display: inline-block;
  background: #4A90D9;
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  margin-right: 12rpx;
  font-weight: 700;
}

/* Options */
.options-wrap {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.option-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #F7F9FC;
  border-radius: 12rpx;
  border: 2rpx solid #E8EDF3;
  transition: all 0.15s;
}

.option-item.selected {
  background: #EBF5FB;
  border-color: #4A90D9;
}

.option-radio {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 3rpx solid #CCC;
  margin-right: 20rpx;
  flex-shrink: 0;
  transition: all 0.15s;
}

.option-radio.radio-active {
  border-color: #4A90D9;
  background: #4A90D9;
  box-shadow: inset 0 0 0 6rpx #fff;
}

.option-label {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.option-item.selected .option-label {
  color: #1E6FB0;
  font-weight: 600;
}

/* Submit */
.submit-area {
  padding: 30rpx 0 20rpx;
}

.submit-btn {
  width: 100%;
}

.btn-disabled {
  background: #B0C4DE !important;
  box-shadow: none !important;
  color: #fff;
}
