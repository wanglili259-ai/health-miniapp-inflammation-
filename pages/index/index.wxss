/* pages/index/index.wxss */

.container {
  padding: 40rpx 30rpx 60rpx;
}

/* Hero card */
.hero-card {
  background: linear-gradient(135deg, #4A90D9, #357ABD);
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(74, 144, 217, 0.35);
}

.hero-icon-emoji {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  line-height: 1;
}

.hero-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 16rpx;
  letter-spacing: 4rpx;
}

.hero-subtitle {
  font-size: 27rpx;
  color: rgba(255, 255, 255, 0.88);
  line-height: 1.7;
}

/* Feature list */
.feature-list {
  padding: 36rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.feature-item:last-child {
  border-bottom: none;
}

.feature-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.feature-icon {
  font-size: 38rpx;
}

.feature-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 6rpx;
}

.feature-desc {
  font-size: 24rpx;
}

/* Disclaimer */
.disclaimer {
  display: flex;
  align-items: flex-start;
  padding: 24rpx 30rpx;
  background: #FFFBF0;
  border: 1rpx solid #FCE588;
}

.disclaimer-icon {
  font-size: 30rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.disclaimer-text {
  font-size: 24rpx;
  color: #7D6608;
  line-height: 1.6;
}

/* Start button */
.start-btn {
  margin: 40rpx 0 0;
  width: 100%;
}

/* History hint */
.history-hint {
  margin-top: 28rpx;
  font-size: 27rpx;
  color: #4A90D9;
}
