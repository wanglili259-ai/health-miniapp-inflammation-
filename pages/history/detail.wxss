.container {
  min-height: 100vh;
  background: var(--bg-primary);
}

.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-text { font-size: 28rpx; color: var(--text-muted); }

.score-overview {
  padding: 40rpx 32rpx 32rpx;
  background: var(--bg-card);
  border-bottom: 1rpx solid var(--border);
  margin-bottom: 8rpx;
}

.date-text {
  display: block;
  font-size: 22rpx;
  color: var(--text-muted);
  margin-bottom: 20rpx;
}

.score-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.big-score {
  font-size: 96rpx;
  font-weight: 800;
  line-height: 1;
}

.score-right {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.level-badge {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 28rpx;
  border-radius: 100rpx;
  border: 1rpx solid;
  font-size: 26rpx;
  font-weight: 600;
}

.score-label { font-size: 22rpx; color: var(--text-muted); }

.section {
  padding: 28rpx 32rpx 12rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

.info-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.info-item {
  background: var(--bg-card);
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  border: 1rpx solid var(--border);
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.info-label { font-size: 20rpx; color: var(--text-muted); }
.info-value { font-size: 26rpx; color: var(--text-primary); font-weight: 500; }

.dim-list {
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  border: 1rpx solid var(--border);
}

.dim-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.dim-item:last-child { margin-bottom: 0; }

.dim-rank {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: var(--bg-elevated);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  color: var(--text-muted);
  flex-shrink: 0;
}

.dim-content { flex: 1; }

.dim-bar-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.dim-name { font-size: 24rpx; color: var(--text-secondary); }
.dim-score { font-size: 24rpx; font-weight: 600; }

.dim-track {
  height: 8rpx;
  background: var(--border);
  border-radius: 100rpx;
  overflow: hidden;
}

.dim-fill { height: 100%; border-radius: 100rpx; }

.principle-card {
  background: var(--bg-card);
  border-radius: 14rpx;
  padding: 24rpx;
  margin-bottom: 14rpx;
  border: 1rpx solid var(--border);
}

.principle-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.p-icon { font-size: 28rpx; }
.p-title { font-size: 26rpx; font-weight: 600; color: var(--text-primary); }
.p-content { font-size: 24rpx; color: var(--text-secondary); line-height: 1.7; }

.action-group {
  background: var(--bg-card);
  border-radius: 14rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 14rpx;
  border: 1rpx solid var(--border);
}

.ag-label {
  display: block;
  font-size: 20rpx;
  color: var(--accent);
  font-weight: 600;
  margin-bottom: 14rpx;
}

.action-item {
  display: flex;
  gap: 10rpx;
  padding: 10rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.action-item:last-child { border-bottom: none; }

.a-icon { font-size: 26rpx; flex-shrink: 0; }
.a-text { font-size: 24rpx; color: var(--text-primary); line-height: 1.6; }

.redflag-card {
  background: rgba(229, 83, 75, 0.08);
  border: 1rpx solid rgba(229, 83, 75, 0.25);
  border-radius: 16rpx;
  padding: 24rpx;
}

.rf-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--accent-danger);
  margin-bottom: 14rpx;
}

.rf-item {
  display: flex;
  gap: 10rpx;
  margin-bottom: 8rpx;
}

.rf-dot { color: var(--accent-danger); font-size: 24rpx; }
.rf-text { font-size: 24rpx; color: var(--text-primary); line-height: 1.6; }
