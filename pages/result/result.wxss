/* pages/result/result.wxss */

.container {
  padding: 30rpx 30rpx 60rpx;
}

/* Score card */
.score-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 50rpx 40rpx 40rpx;
  text-align: center;
  margin-bottom: 24rpx;
  border: 4rpx solid #4A90D9;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.score-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 30rpx;
  letter-spacing: 1rpx;
}

.score-ring-wrap {
  display: flex;
  justify-content: center;
  margin-bottom: 30rpx;
}

.score-ring {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 12rpx solid #4A90D9;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.score-number {
  font-size: 72rpx;
  font-weight: 800;
  line-height: 1;
  color: #4A90D9;
}

.score-max {
  font-size: 26rpx;
  color: #999;
  margin-top: 6rpx;
}

.level-badge {
  display: inline-block;
  background: #4A90D9;
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  padding: 10rpx 40rpx;
  border-radius: 50rpx;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.score-pct {
  font-size: 28rpx;
  font-weight: 600;
}

/* Description */
.description-card {
  padding: 32rpx;
}

.description-text {
  font-size: 28rpx;
  color: #444;
  line-height: 1.8;
}

/* Tips */
.tips-card {
  padding: 32rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.tip-item:last-child {
  margin-bottom: 0;
}

.tip-bullet {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #4A90D9;
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
  margin-top: 2rpx;
}

.tip-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.7;
  flex: 1;
}

/* Summary */
.summary-card {
  padding: 32rpx;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.summary-row:last-child {
  border-bottom: none;
}

.summary-key {
  font-size: 28rpx;
  color: #666;
}

.summary-val {
  font-size: 28rpx;
  color: #222;
}

/* Action area */
.action-area {
  padding-top: 20rpx;
}

.action-area .btn-primary,
.action-area .btn-secondary {
  width: 100%;
}
