.container {
  min-height: 100vh;
  background: var(--bg-primary);
}

/* Score section */
.score-section {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx 48rpx;
  overflow: hidden;
}

.score-bg-glow {
  position: absolute;
  top: -80rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 700rpx;
  height: 700rpx;
  border-radius: 50%;
  pointer-events: none;
}

.score-date {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-bottom: 32rpx;
}

.score-ring {
  display: flex;
  align-items: flex-end;
  gap: 8rpx;
  margin-bottom: 24rpx;
}

.score-num {
  font-size: 128rpx;
  font-weight: 800;
  line-height: 1;
  letter-spacing: -6rpx;
}

.score-unit {
  font-size: 36rpx;
  color: var(--text-muted);
  padding-bottom: 16rpx;
}

.level-badge {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 36rpx;
  border-radius: 100rpx;
  border: 1rpx solid;
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.score-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  text-align: center;
  line-height: 1.6;
  max-width: 560rpx;
}

.completeness-row {
  margin-top: 16rpx;
}

.completeness-warn {
  font-size: 22rpx;
  color: var(--accent-warn);
}

/* Red flags */
.redflag-section {
  padding: 0 32rpx 8rpx;
}

.redflag-card {
  background: rgba(229, 83, 75, 0.08);
  border: 1rpx solid rgba(229, 83, 75, 0.25);
  border-radius: 20rpx;
  padding: 28rpx;
}

.redflag-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--accent-danger);
  margin-bottom: 16rpx;
}

.redflag-list {
  margin-bottom: 16rpx;
}

.redflag-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.redflag-dot {
  color: var(--accent-danger);
  font-size: 28rpx;
  line-height: 1.5;
}

.redflag-text {
  font-size: 26rpx;
  color: var(--text-primary);
  line-height: 1.6;
  flex: 1;
}

.redflag-note {
  font-size: 22rpx;
  color: var(--text-muted);
  line-height: 1.6;
}

/* Sections */
.section-wrap {
  padding: 32rpx 32rpx 8rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

/* Dimension list */
.dim-list {
  background: var(--bg-card);
  border-radius: 20rpx;
  padding: 24rpx;
  border: 1rpx solid var(--border);
}

.dim-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.dim-item:last-child { margin-bottom: 0; }

.dim-rank {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: var(--bg-elevated);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-muted);
  flex-shrink: 0;
}

.dim-content { flex: 1; }

.dim-bar-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.dim-name {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.dim-score {
  font-size: 26rpx;
  font-weight: 600;
}

.dim-track {
  height: 10rpx;
  background: var(--border);
  border-radius: 100rpx;
  overflow: hidden;
}

.dim-fill {
  height: 100%;
  border-radius: 100rpx;
}

/* Principles */
.principle-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.principle-card {
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 28rpx;
  border: 1rpx solid var(--border);
}

.principle-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.principle-icon {
  font-size: 32rpx;
}

.principle-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.principle-content {
  font-size: 25rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

/* Action list */
.action-group {
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid var(--border);
}

.action-group-label {
  display: block;
  font-size: 22rpx;
  color: var(--accent);
  font-weight: 600;
  letter-spacing: 1rpx;
  margin-bottom: 16rpx;
  text-transform: uppercase;
}

.action-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.action-item:last-child { border-bottom: none; }

.action-icon {
  font-size: 28rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.action-text {
  font-size: 26rpx;
  color: var(--text-primary);
  line-height: 1.7;
  flex: 1;
}

/* Nutrition */
.nutrition-card {
  background: rgba(245, 166, 35, 0.08);
  border: 1rpx solid rgba(245, 166, 35, 0.2);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
}

.nutrition-warning {
  font-size: 24rpx;
  color: var(--accent-warn);
  line-height: 1.6;
}

.nutrition-item {
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid var(--border);
}

.nutrition-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--accent);
  margin-bottom: 8rpx;
}

.nutrition-food {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 6rpx;
}

.nutrition-note {
  display: block;
  font-size: 22rpx;
  color: var(--text-muted);
  line-height: 1.6;
}

/* Save section */
.save-section {
  padding: 24rpx 32rpx 40rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.btn-save {
  width: 100%;
  height: 96rpx;
  background: var(--accent);
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  border: none;
  box-shadow: 0 6rpx 24rpx rgba(76, 195, 138, 0.3);
}

.btn-save::after { border: none; }

.btn-save--done {
  background: var(--bg-elevated);
  color: var(--accent);
  border: 1rpx solid var(--accent);
}

.saved-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
}

.saved-text {
  font-size: 28rpx;
  color: var(--accent);
}

.btn-retake {
  width: 100%;
  height: 88rpx;
  background: transparent;
  border: 1rpx solid var(--border-light);
  border-radius: 44rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
}

.btn-retake::after { border: none; }

.btn-home {
  width: 100%;
  height: 88rpx;
  background: transparent;
  border: 1rpx solid var(--border);
  border-radius: 44rpx;
  font-size: 28rpx;
  color: var(--text-muted);
}

.btn-home::after { border: none; }

/* Disclaimer */
.disclaimer-wrap {
  margin: 0 32rpx 60rpx;
  padding: 28rpx;
  background: rgba(107, 116, 133, 0.05);
  border-radius: 16rpx;
  border: 1rpx solid var(--border);
}

.disclaimer-title {
  display: block;
  font-size: 22rpx;
  color: var(--text-muted);
  font-weight: 600;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.disclaimer-text {
  font-size: 22rpx;
  color: var(--text-muted);
  line-height: 1.8;
}
