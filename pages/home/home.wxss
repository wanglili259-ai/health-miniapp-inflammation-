.container {
  min-height: 100vh;
  background: var(--bg-primary);
}

/* Header */
.header {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx 60rpx;
  overflow: hidden;
}

.header-glow {
  position: absolute;
  top: -100rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 600rpx;
  height: 600rpx;
  background: radial-gradient(circle, rgba(76, 195, 138, 0.12) 0%, transparent 70%);
  pointer-events: none;
}

.logo-wrap {
  width: 120rpx;
  height: 120rpx;
  background: var(--bg-elevated);
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
  border: 1rpx solid var(--border-light);
}

.logo-icon {
  font-size: 60rpx;
}

.app-title {
  font-size: 52rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
}

.app-subtitle {
  font-size: 28rpx;
  color: var(--accent);
  margin-bottom: 8rpx;
}

.app-version {
  font-size: 22rpx;
  color: var(--text-muted);
}

/* Login status */
.login-status-bar {
  margin: 0 32rpx 24rpx;
  padding: 18rpx 28rpx;
  background: rgba(76, 195, 138, 0.08);
  border: 1rpx solid rgba(76, 195, 138, 0.2);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.login-status-bar--guest {
  background: rgba(107, 116, 133, 0.08);
  border-color: var(--border);
}

.login-icon {
  font-size: 28rpx;
  color: var(--accent);
}

.login-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* Actions */
.actions-wrap {
  padding: 0 32rpx;
  margin-bottom: 40rpx;
}

.btn-start {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  width: 100%;
  height: 104rpx;
  background: var(--accent);
  border-radius: 52rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 4rpx;
  margin-bottom: 24rpx;
  border: none;
  box-shadow: 0 8rpx 32rpx rgba(76, 195, 138, 0.3);
}

.btn-start::after { border: none; }

.btn-start-icon {
  font-size: 28rpx;
}

.action-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.btn-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 120rpx;
  background: var(--bg-card);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--border);
  position: relative;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.btn-card::after { border: none; }

.btn-card-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.btn-card-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.btn-card-count {
  position: absolute;
  top: 16rpx;
  right: 20rpx;
  background: var(--accent);
  color: #fff;
  font-size: 20rpx;
  min-width: 36rpx;
  height: 36rpx;
  border-radius: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  font-weight: 600;
}

.btn-login {
  width: 100%;
  height: 80rpx;
  background: transparent;
  border: 1rpx solid var(--border-light);
  border-radius: 40rpx;
  font-size: 26rpx;
  color: var(--text-muted);
}

.btn-login::after { border: none; }

/* Intro section */
.intro-section {
  padding: 0 32rpx 80rpx;
}

.intro-card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 36rpx;
  margin-bottom: 28rpx;
  border: 1rpx solid var(--border);
}

.intro-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

.intro-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

/* Step cards */
.step-cards {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
}

.step-card {
  flex: 1;
  background: var(--bg-elevated);
  border-radius: var(--radius-md);
  padding: 24rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 1rpx solid var(--border);
}

.step-num {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--accent);
  margin-bottom: 8rpx;
}

.step-text {
  font-size: 22rpx;
  color: var(--text-secondary);
  text-align: center;
}

.step-divider {
  font-size: 28rpx;
  color: var(--text-muted);
  padding: 0 12rpx;
}

/* Disclaimer */
.disclaimer-card {
  background: rgba(229, 83, 75, 0.06);
  border: 1rpx solid rgba(229, 83, 75, 0.15);
  border-radius: var(--radius-md);
  padding: 24rpx 28rpx;
}

.disclaimer-text {
  font-size: 24rpx;
  color: var(--text-muted);
  line-height: 1.7;
}
