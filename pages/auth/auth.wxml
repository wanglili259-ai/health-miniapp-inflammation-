<view class="container">
  <!-- 顶部图示 -->
  <view class="top-art">
    <view class="art-circle"></view>
    <text class="art-icon">📱</text>
  </view>

  <!-- 标题区 -->
  <view class="title-section">
    <text class="title">微信手机号登录</text>
    <text class="subtitle">登录后可将测评结果同步至云端，随时查看历史记录</text>
  </view>

  <!-- 隐私说明 -->
  <view class="privacy-card">
    <view class="privacy-row">
      <text class="privacy-icon">🔒</text>
      <text class="privacy-text">手机号仅用于账号标识，不会用于营销推送</text>
    </view>
    <view class="privacy-row">
      <text class="privacy-icon">☁️</text>
      <text class="privacy-text">数据存储在微信云开发，您可随时申请删除</text>
    </view>
    <view class="privacy-row">
      <text class="privacy-icon">🛡️</text>
      <text class="privacy-text">测评数据仅您本人可查看，严格保护隐私</text>
    </view>
  </view>

  <!-- 授权按钮 -->
  <view class="btn-wrap" wx:if="{{ !loading }}">
    <button
      class="btn-phone"
      open-type="getPhoneNumber"
      bindgetphonenumber="onGetPhoneNumber"
    >
      <text class="btn-phone-icon">📞</text>
      <text>微信手机号一键授权</text>
    </button>
    <button class="btn-skip" bindtap="skipLogin">暂不登录，继续使用</button>
  </view>

  <!-- 加载中 -->
  <view class="loading-wrap" wx:else>
    <text class="loading-text">登录中...</text>
  </view>

  <!-- 底部提示 -->
  <view class="footer-note">
    <text class="footer-text">登录即代表同意</text>
    <text class="footer-link" bindtap="viewPrivacy">《隐私政策》</text>
    <text class="footer-text">与</text>
    <text class="footer-link" bindtap="viewTerms">《用户协议》</text>
  </view>
</view>
