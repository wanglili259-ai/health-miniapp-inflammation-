.container {
  min-height: 100vh;
  background: var(--bg-primary);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx 80rpx;
}

.top-art {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 48rpx;
}

.art-circle {
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(76, 195, 138, 0.3);
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0% { transform: scale(1); opacity: 0.8; }
  50% { transform: scale(1.08); opacity: 0.4; }
  100% { transform: scale(1); opacity: 0.8; }
}

.art-icon {
  font-size: 80rpx;
  z-index: 1;
}

.title-section {
  width: 100%;
  text-align: center;
  margin-bottom: 48rpx;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.7;
}

.privacy-card {
  width: 100%;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 36rpx;
  margin-bottom: 48rpx;
  border: 1rpx solid var(--border);
}

.privacy-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.privacy-row:last-child {
  margin-bottom: 0;
}

.privacy-icon {
  font-size: 32rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.privacy-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

.btn-wrap {
  width: 100%;
  margin-bottom: 24rpx;
}

.btn-phone {
  width: 100%;
  height: 104rpx;
  background: var(--accent);
  border-radius: 52rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
  border: none;
  box-shadow: 0 8rpx 32rpx rgba(76, 195, 138, 0.3);
}

.btn-phone::after { border: none; }

.btn-phone-icon {
  font-size: 32rpx;
}

.btn-skip {
  width: 100%;
  height: 88rpx;
  background: transparent;
  border: 1rpx solid var(--border-light);
  border-radius: 44rpx;
  font-size: 28rpx;
  color: var(--text-muted);
}

.btn-skip::after { border: none; }

.loading-wrap {
  padding: 60rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.footer-note {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 4rpx;
  margin-top: auto;
  padding-top: 40rpx;
}

.footer-text {
  font-size: 22rpx;
  color: var(--text-muted);
}

.footer-link {
  font-size: 22rpx;
  color: var(--accent);
}
